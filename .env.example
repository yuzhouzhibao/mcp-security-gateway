APP_NAME="MCP Security Gateway"
APP_ENV=local
LOG_LEVEL=INFO
DATABASE_URL=postgresql+psycopg://mcp_gateway:mcp_gateway_secret@postgres:5432/mcp_security_gateway
TEST_DATABASE_URL=postgresql+psycopg://mcp_gateway:mcp_gateway_secret@localhost:5432/mcp_security_gateway_test
API_KEY_PEPPER=replace-with-deployment-pepper
ADMIN_API_KEY_HASH=replace-with-hmac-sha256-admin-key-hash
APPROVAL_REQUEST_TTL_SECONDS=900
MCP_CALL_TIMEOUT_SECONDS=10
